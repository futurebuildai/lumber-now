# LumberNow Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- Required ---
DATABASE_URL=postgres://lumber:lumber@localhost:5432/lumber_now?sslmode=disable
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars-long
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
CORS_ORIGINS=http://localhost:5173

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=lumber-now
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Optional: Google Cloud Speech-to-Text (for voice transcription) ---
# GCLOUD_CREDENTIALS_FILE=./gcloud-credentials.json

# --- Optional: Resend Email (for order emails) ---
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=LumberNow <orders@lumbernow.com>

# --- Server ---
PORT=8080
LOG_LEVEL=info

# --- Database Connection Pool ---
# DB_MAX_CONNS=25
# DB_MIN_CONNS=5

# --- Worker (only for cmd/worker) ---
# WORKER_CONCURRENCY=3
# WORKER_POLL_INTERVAL=10s
# WORKER_BATCH_SIZE=10
# WORKER_STUCK_TIMEOUT=15m
# WORKER_METRICS_PORT=9090
